# .env.example — commit this file. Never commit .env
# Copy to .env and fill in real values.
# .env is in .gitignore

# ── Phase 1: Molina ──────────────────────────────────────────────────────────
MOLINA_USER=
MOLINA_PASS=

# ── Phase 2: Ambetter (fill in Phase 2) ─────────────────────────────────────
AMBETTER_USER=
AMBETTER_PASS=

# ── Phase 3: Google Sheets (fill in Phase 3) ────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/service_account.json
DRIVE_FOLDER_ID=
# Optional: pin an existing sheet ID to bypass Drive file creation
# (use when Drive returns storageQuotaExceeded — abuse prevention on new projects)
# Format: SHEET_ID_{MONTH}_{YEAR} — add one line per month as needed
SHEET_ID_APRIL_2026=

# ── Phase 4: Cigna (fill in Phase 4) ────────────────────────────────────────
# One set per agent — add rows for all 19 agents
CIGNA_USER_AGENT01=
CIGNA_PASS_AGENT01=
WEBMAIL_USER_AGENT01=
WEBMAIL_PASS_AGENT01=

# ── Phase 5: United (fill in Phase 5) ───────────────────────────────────────
UHC_USER=
UHC_PASS=

# ── Phase 6: Oscar (fill in Phase 6) ────────────────────────────────────────
OSCAR_USER=
OSCAR_PASS=
