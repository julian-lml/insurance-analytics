# ─────────────────────────────────────────────────────────────────────────────
# agents.yaml — Carrier agent credentials
# ─────────────────────────────────────────────────────────────────────────────
#
# COPY this file to config/agents.yaml and fill in real credentials.
# config/agents.yaml is in .gitignore — never committed.
#
# Structure: each carrier has a list of agents. Each agent has:
#   name:  display name (used in R1/R2 records and logs)
#   user:  portal login username
#   pass:  portal login password
#   email: (Cigna only) webmail address for 2FA codes
#
# To add/remove an agent: edit this file. No code changes needed.
# ─────────────────────────────────────────────────────────────────────────────

molina:
  - name: "Justin Santa"
    user: "jsanta@example.com"
    pass: "changeme"

  - name: "Maria Lopez"
    user: "mlopez@example.com"
    pass: "changeme"

  # Add all 19 agents here. One block per agent.
  # The downloader loops through this list automatically.

